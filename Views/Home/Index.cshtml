@model IEnumerable<Demo_Jquery.Models.Employee>

@{
    ViewData["Title"] = "Demostración de jQuery DataTables";
}

<div class="text-center">
    <h1 class="display-4">Demostración de jQuery DataTables</h1>
    <p>Esta página muestra una tabla simple con DataTables, búsqueda integrada y un listener de eventos.</p>
</div>

<div class="btn-group mb-4" role="group">
    <button id="btnActivos" class="btn btn-outline-primary">Activos</button>
    <button id="btnTodos" class="btn btn-outline-secondary">Todos</button>
    <button id="btnSalario" class="btn btn-outline-warning">Salario</button>
    <button id="btnReset" class="btn btn-outline-danger">Reset</button>
</div>

<table id="employeesTable" class="table table-striped table-bordered">
    <thead>
        <!-- Se incorpora la columna Email, Cargo, Salario y Estado para mostrar en la tabla y usar en el modal -->
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Departamento</th>
            <th>Cargo</th>
            <th>Salario</th>
            <th>Estado</th>
            <th>Detalles</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var employee in Model)
        {
            <!-- Se incorpora el atributo Email, Cargo, Salario y IsActive para mostrar en la tabla y usar en el modal -->
            <tr data-id="@employee.Id">
                <td>@employee.Id</td>
                <td>@employee.Name</td>
                <td>@employee.Email</td>
                <td>@employee.Department</td>
                <td>@employee.Cargo</td>
                <td>$@employee.Salario</td>
                <td>@(employee.IsActive? "Activo" : "Inactivo")</td>
                <td><button class="btn btn-outline-info btnDetalles">Ver</button></td> <!-- Botón para mostrar detalles en el modal -->
            </tr>
        }
    </tbody>
</table>

<!-- Modal que muestra la informacion del empleado -->

<div class="modal fade" id="employeeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Detalle del Empleado</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <p><strong>Nombre:</strong> <span id="mName"></span></p>
                <p><strong>Email:</strong> <span id="mEmail"></span></p>
                <p><strong>Departamento:</strong> <span id="mDept"></span></p>
                <p><strong>Cargo:</strong> <span id="mCargo"></span></p>
                <p><strong>Salario:</strong> <span id="mSalario"></span></p>
                <p><strong>Estado:</strong> <span id="mEstado"></span></p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-outline-danger" data-bs-dismiss="modal">Cerrar</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script>
        $(document).ready(function () {
            // Inicializar DataTables en la tabla con ID 'employeesTable'
            //$('#employeesTable').DataTable({
            // searching: true,
            // paging: true,
            // pageLength: 15,
            // sort: false,
            // });

            var table = $('#employeesTable').DataTable({

                paging: true, // Habilitar paginación para dividir los datos en páginas
                searching: true, // Habilitar la barra de búsqueda integrada de DataTables
                pageLength: 5, // Mostrar 5 filas por página inicialmente
                lengthMenu: [5, 10, 15, 20, 25 ], // Opciones para cambiar el número de filas por página
                language: {

                    // Configurar el idioma en español para una mejor experiencia
                    "lengthMenu": "Mostrar _MENU_ entradas por página",
                    "zeroRecords": "No se encontraron resultados",
                    "info": "Mostrando página _PAGE_ de _PAGES_",
                    "infoEmpty": "No hay registros disponibles",
                    "infoFiltered": "(filtrado de _MAX_ registros totales)",
                    "search": "Buscar:",
                    "paginate": {
                        "first": "Primero",
                        "last": "Último",
                        "next": "Siguiente",
                        "previous": "Anterior"
                    }
                }
            });

         // Variable para controlar el filtro de activos

         var soloActivos = false;

        $.fn.dataTable.ext.search.push(function (settings, data) {

            var estado = data[6];

            if (soloActivos && estado !== "Activo") { 
                return false;
            }

            return true;
        });

            $('#btnActivos').on('click', function () {
            soloActivos = true;
            table.draw();
        });

        $('#btnTodos').on('click', function () {
            soloActivos = false;
            table.draw();
        });

         // Variable para controlar el ordenamiento por salario

         var asc = false;

        $('#btnSalario').on('click', function () {
            asc = !asc;
            table.order([5, asc ? 'asc' : 'desc']).draw();
        });

        // Listener para el botón de detalles en cada fila

         $('#employeesTable tbody').on('click', '.btnDetalles', function (e) {
            e.stopPropagation();

            var row = table.row($(this).closest('tr')).data();

            if (!row) return;

            // Crear un objeto con los datos del empleado para mostrar en el modal

            var emp = {
                name: row[1],
                email: row[2],
                dept: row[3],
                cargo: row[4],
                salario: row[5],
                estado: row[6]
            };

            // Rellenar el contenido del modal con los datos del empleado

            $('#mName').text(emp.name);
            $('#mEmail').text(emp.email);
            $('#mDept').text(emp.dept);
            $('#mCargo').text(emp.cargo);
            $('#mSalario').text(emp.salario);
            $('#mEstado').text(emp.estado);

            new bootstrap.Modal(document.getElementById('employeeModal')).show();

        });

        // Botón para resetear filtros y orden
         $('#btnReset').on('click', function () {
            soloActivos = false;
            table.search('').draw();
            table.order([0, 'asc']).draw();

        });

            // Datos de empleados para el autocompletado
            var employees = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

            // Utiliza un evento keyup para sugerencias manuales (sin jQuery UI)
            //$('#searchName').on('keyup', LlamarPrediccion());
            //$('#searchName').on('keyup', console.log("Value"));

            $('#searchName').on('keyup', function() {
                var term = $(this).val().trim().toLowerCase();

               // var term2 = $('#employeesTable').val().trim().toLowerCase();
                var $suggestions = $('#suggestions');

                //Cuando borro se eliminan las suggetions
                if (!term) {
                    $suggestions.empty().hide();
                    return;
                }

                //ESTA PARTE ALTAMENTE VARIABLE
                //filtrado en base  a Term
                var results = employees.filter(function(emp) {
                    var empName = (emp.name || emp.Name || '').toString();
                    return empName.toLowerCase().includes(term);
                });

                //Tenia valor anterior se borra
                $suggestions.empty();


                //pintar el resultado del mapeo
                if (results.length === 0) {
                    $('<li class="list-group-item list-group-item-secondary">No se encontraron nombres</li>').appendTo($suggestions);
                    $suggestions.show();
                    return;
                }

                console.log("Lista:" + employees);

                results.slice(0, 8).forEach(function(emp) {
                    var empName = (emp.name || emp.Name || '').toString();
                    var empId = emp.id || emp.Id || '';
                    var empEmail = emp.email || emp.Email || '';
                    var empDepartment = emp.department || emp.Department || '';
                    var empCar = emp.car || emp.Cargo || '';

                    var $item = $('<li class="list-group-item list-group-item-action" style="cursor: pointer;"></li>');
                    $item.text(empName);
                    $item.on('click', function() {
                        $('#searchName').val(empName);
                        $suggestions.empty().hide();

                        $('#empId').text(empId);
                        $('#empName').text(empName);
                        $('#empEmail').text(empEmail);
                        $('#empDept').text(empDepartment);
                        $('#empCar').text(empCar);
                        $('#employeeDetails').show();
                    });
                    $suggestions.append($item);
                });

                $suggestions.show();
            });

            $(document).on('click', function(e){
                if (!$(e.target).closest('#searchName, #suggestions').length) {
                    $('#suggestions').empty().hide();
                }
            });
        });

    </script>

}

